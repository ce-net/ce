# CE deployment environment variables
# Copy to .env and fill in your values.

# Hetzner Cloud API token (read + write)
# Create at: https://console.hetzner.cloud → Security → API Tokens
HETZNER_API_TOKEN=

# Name of the SSH key registered in your Hetzner project
# Register at: https://console.hetzner.cloud → Security → SSH Keys
CE_SSH_KEY_NAME=ce-deploy

# Absolute path to the corresponding private key on this machine
CE_SSH_KEY_PATH=~/.ssh/ce_deploy
